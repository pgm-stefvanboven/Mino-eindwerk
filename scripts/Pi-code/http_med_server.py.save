            with frame_lock:
                latest_frame = jpg_bytes
                latest_ts = time.time()

        except Exception as e:
            print(f"Camera loop fout: {e}")
            time.sleep(0.5)

        # houd FPS stabiel zonder backlog
        dt = time.time() - t0
        sleep_time = interval - dt
        if sleep_time > 0:
            time.sleep(sleep_time)

threading.Thread(target=camera_loop, daemon=True).start()

def mjpeg_stream():
    while True:
        with frame_lock:
            frame = latest_frame

        if frame is None:
            time.sleep(0.05)
            continue

        yield (
            b"--frame\r\n"
            b"Content-Type: image/jpeg\r\n"
            b"Content-Length: " + str(len(frame)).encode() + b"\r\n\r\n" +
            frame + b"\r\n"
        )

# ----------------------------
# ROUTES
# ----------------------------
@app.get("/health")
def health():
    age = time.time() - latest_ts if latest_ts else None
    return jsonify({
        "ok": True,
        "video_frame_age_sec": age,
        "video_size": list(VIDEO_SIZE),
        "video_fps": VIDEO_FPS,
        "jpeg_quality": JPEG_QUALITY
    })

@app.get("/video_feed")
def video_feed():
    return Response(
        mjpeg_stream(),
        mimetype="multipart/x-mixed-replace; boundary=frame",
        headers={
            "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0",
            "Pragma": "no-cache",
        },
    )

@app.get("/snapshot.jpg")
def snapshot():
    # handig om te testen of de jpeg echt correct is
    with frame_lock:
        frame = latest_frame
    if frame is None:
        return ("No frame yet", 503)
    return Response(frame, mimetype="image/jpeg", headers={"Cache-Control": "no-store"})

# ----------------------------
# Medicatie API
# ----------------------------
medication_data = [
    {"id": 1, "time": "08:00", "name": "Paracetamol", "taken": False},
    {"id": 2, "time": "12:00", "name": "Bloeddrukpil", "taken": False},
]

@app.get("/medicijnen")
def get_meds():
    return jsonify(medication_data)

@app.post("/medicijnen/<int:id>/bevestig")
def confirm_med(id):
    send_cmd("CMD_BUZZER#1")
    time.sleep(0.5)
    send_cmd("CMD_BUZZER#0")
    return jsonify({"status": "success", "buzzer": "beep", "id": id})

if __name__ == "__main__":
    print("HTTP Medicatie Bridge draait op poort 5001...")
    app.run(host="0.0.0.0", port=HTTP_PORT, debug=False, threaded=True, use_reloader=False)
