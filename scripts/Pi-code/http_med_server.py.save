from flask import Flask, jsonify, Response, send_file
from flask_cors import CORS
import socket
import time
import threading
import io

from picamera2 import Picamera2
import cv2

app = Flask(__name__)
CORS(app)

# ----------------------------
# INSTELLINGEN
# ----------------------------
ROBOT_IP = "127.0.0.1"
CMD_PORT = 5000
HTTP_PORT = 5001

VIDEO_SIZE = (640, 480)   # als nodig: (480, 360)
VIDEO_FPS = 12            # stabieler dan 15
JPEG_QUALITY = 70         # als nodig: 60

# ----------------------------
# COMMAND BRIDGE
# ----------------------------
def send_cmd(command: str) -> bool:
    try:
        client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        client.settimeout(2)
        client.connect((ROBOT_IP, CMD_PORT))
        client.sendall((command + "\n").encode("utf-8"))
        client.close()
        print(f"Gestuurd: {command}")
        return True
    except Exception as e:
        print(f"Fout bij sturen commando '{command}': {e}")
        return False

# ----------------------------
# CAMERA THREAD: latest JPEG
# ----------------------------
latest_frame = None
latest_ts = 0.0
frame_lock = threading.Lock()

def camera_loop():
    global latest_frame, latest_ts

    picam2 = Picamera2()

    # Laat Pi 5 kiezen (vaak XBGR8888). Wij detecteren kanalen automatisch.
    config = picam2.create_video_configuration(
        main={"size": VIDEO_SIZE},
        controls={"FrameRate": float(VIDEO_FPS)}
    )
    picam2.configure(config)
    picam2.start()

    # warm-up voor exposure/awb
    time.sleep(1.0)

    interval = 1.0 / max(1, int(VIDEO_FPS))
    encode_params = [int(cv2.IMWRITE_JPEG_QUALITY), int(JPEG_QUALITY)]

    print(f"Camera gestart: size={VIDEO_SIZE}, fps={VIDEO_FPS}, jpeg_quality={JPEG_QUALITY}")

