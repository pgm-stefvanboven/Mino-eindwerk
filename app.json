{
  "expo": {
    "name": "Mino",
    "slug": "mino-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "minoapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#09090b",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stefvanboven.minoapp"
    },
    "android": {
      "package": "com.stefvanboven.minoapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#09090b"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.svg",
      "description": "Mino: Slimme zorg, gerust gevoel."
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090b"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Mino heeft toegang nodig tot je camera om medicijnen te scannen."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4137b61f-247e-4811-aea5-a53fc50ba7d7"
      }
    }
  }
}
